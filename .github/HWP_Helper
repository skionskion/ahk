; -------------------- 함수 정의 --------------------
CreateSymbolButtons(arr, tabIndex) {
    global MyGui, MyTab, SymbolButtons
    MyTab.UseTab(tabIndex)
    for index, symbol in arr {
        col := Mod(index - 1, 5)
        row := Floor((index - 1) / 5)
        x := 20 + (col * 42)
        y := 380 + (row * 40)
        btn := MyGui.Add("Button", Format("x{} y{} w37 h30 Hidden", x, y), symbol)
        btn.OnEvent("Click", SymbolClick)
        SymbolButtons.Push(btn)
    }
    MyTab.UseTab()
}

ToggleSymbol(*) {
    global MyGui, MyTab, SymbolButtons, isSymbolMode, BtnToggle, NormalHeight, SymbolHeight
    isSymbolMode := !isSymbolMode
    if isSymbolMode {
        MyTab.Visible := true
        for btn in SymbolButtons
            btn.Visible := true
        BtnToggle.Text := "기본"
        MyGui.Show("h" SymbolHeight)
    } else {
        MyTab.Visible := false
        for btn in SymbolButtons
            btn.Visible := false
        BtnToggle.Text := "기호"
        MyGui.Show("h" NormalHeight)
    }
}

SymbolClick(ctrl, *) {
    ChosenSymbol := ctrl.Text
    if (ChosenSymbol = "")
        return
    if (ChosenSymbol = "특수") {
        Symbols := Chr(0x274D) . Chr(0x2022)
        InsertHWPText(Symbols)
    } else {
        InsertHWPText(ChosenSymbol)
    }
}

