UpdateDoc(*) {
    global MyGui, hwp, Temp_Var
    MyGui.Submit(false)
    MyDoc := MyGui["MyDoc"].Text

    if (MyDoc = "각종서식") {
        return
    } else if (MyDoc = "HWP열기") {
        result := MsgBox("HWP 파일을 열겠습니까?`n기존 파일은 제어가 불가능합니다.", "파일 열기", "Y/N Icon? 32")
        if (result = "No")
            return
        Import_Files()
        return
    } else if (MyDoc = "샘플열기") {
        F_FileName := A_ScriptDir "\\DATA\\Form_HWP.hwp"
        Run F_FileName
        WinActivate "ahk_exe Hwp.exe"
        return
    } else if (MyDoc = "A3보고서") {
        hwp.HAction.Run("SelectAll")
        hwp.HAction.Run("Delete")
        Import_HWP_A3("Form_A3.hwp")
        hwp.HAction.Run("MovePageBegin")
        Temp_Var := MyDoc
        WinActivate "ahk_exe hwp.exe"
        return
    }

    hwp.HAction.Run("MovePageBegin")
    hwp.HAction.Run("SelectAll")
    hwp.HAction.Run("Delete")
    Paper_Setting_A4()
    Temp_Var := MyDoc

    forms := Map()
    forms["보고전"] := [2, 2]
    forms["공문작성"] := [4, 4]
    forms["출장복명"] := [5, 5]
    forms["회의결과"] := [14, 14]
    forms["목차"] := [1, 1]
    forms["A4_A3변환"] := [6, 9]
    forms["A4보고서"] := [10, 12]
    forms["보고2"] := [13, 13]

    if forms.Has(MyDoc) {
        startPage := forms[MyDoc][1]
        endPage := forms[MyDoc][2]
        Keep_Page(startPage, endPage)
    }
    hwp.HAction.Run("MoveDocBegin")
    WinActivate "ahk_exe hwp.exe"
}

UpdateFont(*) {
