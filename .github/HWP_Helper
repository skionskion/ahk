Insert_File(FileName) {
    global hwp
    hset1 := hwp.HParameterSet.HInsertFile
    hwp.HAction.GetDefault("InsertFile", hset1.HSet)
    hset1.KeepSection := 0
    hset1.KeepCharshape := 0
    hset1.KeepParashape := 0
    hset1.KeepStyle := 0
    hset1.FileName := A_ScriptDir "\DATA\" FileName ".hwp"
    hwp.HAction.Execute("InsertFile", hset1.HSet)
}

Keep_Page(FromPG, EndPG) {
    ;~ global MyStatus, hwp, MyGui
    MyStatus.Value := "★ 처리중...  되돌리기는 Ctrl+Z"
    MyStatus.SetFont("s11 cRed")

    Insert_File("Form_HWP")
    hwp.XHwpWindows.Item(0).Visible := false
    Tset := hwp.HParameterSet.HGotoE

    hwp.HAction.GetDefault("Goto", Tset.HSet)
    Tset.HSet.SetItem("DialogResult", EndPG + 1)
    Tset.SetSelectionIndex := 1
    hwp.HAction.Execute("Goto", Tset.HSet)
    hwp.HAction.Run("MoveLeft")
    hwp.HAction.Run("MoveSelTopLevelEnd")
    hwp.HAction.Run("Delete")

    hwp.HAction.GetDefault("Goto", Tset.HSet)
    Tset.HSet.SetItem("DialogResult", FromPG)
    Tset.SetSelectionIndex := 1
    hwp.HAction.Execute("Goto", Tset.HSet)
    hwp.HAction.Run("MoveSelTopLevelBegin")
    if (FromPG != 1)
        hwp.HAction.Run("Delete")

    hwp.XHwpWindows.Item(0).Visible := true

    WarmMsg := [
        "작업 준비 완료! 마음껏 편집하세요.", "어제는 역사이고, 내일은 수수께끼, 오늘은 선물입니다.", "작은 일에 정성을 다하세요.", "가장 큰 위험은 아무것도 시도하지 않는 것입니다.",
        "당신이 헛되이 보낸 오늘은, 어제 죽은 이가 그토록 원했던 내일입니다."
    ]
    MsgIndex := Random(1, WarmMsg.Length)
    SelectedMsg := WarmMsg[MsgIndex]
    MyStatus.SetFont("s9 cGray")
    MyStatus.Value := SelectedMsg
}

InsertHWPText(textValue) {
    pset := hwp.HParameterSet.HInsertText
    hwp.HAction.GetDefault("InsertText", pset.HSet)
    pset.Text := textValue
    hwp.HAction.Execute("InsertText", pset.HSet)
}

hwp_Enter(num := 1) {
    loop num
        hwp.HAction.Run("BreakPara")
}

InputText(text) {
    hset := hwp.HParameterSet.HInsertText
    hwp.HAction.GetDefault("InsertText", hset.HSet)
    hset.Text := text
    hwp.HAction.Execute("InsertText", hset.HSet)
}

InputText_Enter(text) {
    InputText(text)
    hwp.HAction.Run("BreakPara")
}

hwp_LineSpace(&num) {
    hwp.HAction.GetDefault("ParagraphShape", hwp.HParameterSet.HParaShape.HSet)
    hwp.HParameterSet.HParaShape.LineSpacing := num
    hwp.HAction.Execute("ParagraphShape", hwp.HParameterSet.HParaShape.HSet)
}

Font_Size(fontName, fontSize) {
    hIns := hwp.HParameterSet.HInsertText
    hwp.HAction.GetDefault("InsertText", hIns.HSet)
    hIns.Text := "1"
    hwp.HAction.Execute("InsertText", hIns.HSet)
    hwp.HAction.Run("MoveSelLineBegin")
    hChar := hwp.HParameterSet.HCharShape
    hwp.HAction.GetDefault("CharShape", hChar.HSet)
    fontType := hwp.FontType("TTF")
    hChar.FaceNameHangul := fontName
    hChar.FontTypeHangul := fontType
    hChar.FaceNameOther := fontName
    hChar.FontTypeOther := fontType
    hChar.FaceNameSymbol := fontName
    hChar.FontTypeSymbol := fontType
    hChar.Height := hwp.PointToHwpUnit(fontSize)
    hwp.HAction.Execute("CharShape", hChar.HSet)
    hwp.HAction.Run("DeleteBack")
}

hwp_Save(FileName) {
    global hwp
    SaveDir := A_ScriptDir "\"
    if !DirExist(SaveDir)
        DirCreate SaveDir

    FileCount := 0
    loop files, SaveDir "*.hwp"
        FileCount++

    SplitPath FileName, , , , &PureName
    CurrentTime := FormatTime(, "yyMMdd_HHmm")
    BaseFileName := PureName "_" CurrentTime
    FinalPath := SaveDir BaseFileName ".hwp"
    if FileExist(FinalPath) {
        loop 100 {
            TempPath := SaveDir BaseFileName "_" A_Index ".hwp"
            if !FileExist(TempPath) {
                FinalPath := TempPath
                break
            }
        }
    }
    pset := hwp.HParameterSet.HFileOpenSave
    hwp.HAction.GetDefault("FileSaveAs_S", pset.HSet)
    pset.FileName := FinalPath
    pset.Format := "HWP"
    pset.Attributes := 0
    return hwp.HAction.Execute("FileSaveAs_S", pset.HSet)
}

