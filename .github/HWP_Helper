    hChar := hwp.HParameterSet.HCharShape
    fontType := hwp.FontType("TTF")
    hwp.HAction.GetDefault("CharShape", hChar.HSet)

    hChar.FaceNameHangul := MyFont
    hChar.FontTypeHangul := fontType
    hChar.FaceNameLatin := MyFont
    hChar.FontTypeLatin := fontType
    hChar.FaceNameUser := MyFont
    hChar.FontTypeUser := fontType
    hChar.FaceNameHanja := MyFont
    hChar.FontTypeHanja := fontType
    hChar.FaceNameSymbol := MyFont
    hChar.FontTypeSymbol := fontType
    hChar.FaceNameOther := MyFont
    hChar.FontTypeOther := fontType

    hwp.HAction.Execute("CharShape", hChar.HSet)
}

