UpdateColor(*) {
    global MyGui, hwp
    MyGui.Submit(false)
    MyColor := Trim(MyGui["MyColor"].Text)

    ColorMap := Map(
        "연빨강", 0xCCCCFF, "빨강", 0x0000FF, "진빨강", 0x000099
        , "연주황", 0xCCE5FF, "주황", 0x0066FF, "진주황", 0x0044CC
        , "연노랑", 0xCCFFFF, "노랑", 0x00FFFF, "진노랑", 0x00CCCC
        , "연초록", 0xCCFFCC, "초록", 0x008000, "진초록", 0x006400
        , "연파랑", 0xFFCCCC, "파랑", 0xFF0000, "진파랑", 0x990000
        , "연남색", 0xFFCCDD, "남색", 0x800000, "진남색", 0x400000
        , "연보라", 0xFFCCFF, "보라", 0x800080, "진보라", 0x4B0082
        , "검정", 0x000000, "회색", 0x808080, "연회색", 0xEEEEEE
        , "흰색", 0xFFFFFF)

    if (MyColor = "색상" || !ColorMap.Has(MyColor))
        return

    IsTable := MyGui["IsTable"].Value
    IsShade := MyGui["IsShade"].Value

    if IsTable {
        bset := hwp.HParameterSet.HCellBorderFill
        hwp.HAction.GetDefault("CellFill", bset.HSet)
        bset.FillAttr.Type := hwp.BrushType("NullBrush|WinBrush")
        bset.FillAttr.WinBrushFaceColor := ColorMap[MyColor]
        bset.FillAttr.WinBrushHatchColor := 0x999999
        bset.FillAttr.WinBrushFaceStyle := hwp.HatchStyle("None")
        bset.FillAttr.WindowsBrush := 1
        hwp.HAction.Execute("CellFill", bset.HSet)
    } else {
        hChar := hwp.HParameterSet.HCharShape
        hwp.HAction.GetDefault("CharShape", hChar.HSet)
        if IsShade {
            hChar.ShadeColor := ColorMap[MyColor]
        } else {
            hChar.TextColor := ColorMap[MyColor]
        }
        hwp.HAction.Execute("CharShape", hChar.HSet)
    }
    MyGui["IsShade"].Value := 0
    MyGui["IsTable"].Value := 0
    MyGui["MyColor"].Text := "색상"
}

